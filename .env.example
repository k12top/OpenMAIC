# =============================================================================
# OpenMAIC Environment Variables
# Copy this file to .env.local and fill in the values you need.
# All variables are optional — only configure the providers you want to use.
# You can also use server-providers.yml for configuration (see docs).
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
# Format: {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL (optional), {PROVIDER}_MODELS (optional, comma-separated)
#
# {PROVIDER}_MODELS notes:
#   - Comma-separated; whitespace is trimmed.
#   - Order is preserved: the first id appears first in the UI dropdown.
#   - Acts as a strict whitelist against the built-in catalog in lib/ai/providers.ts.
#     Ids not found there are logged once on the client and dropped silently.
#   - Leave empty to show the full built-in model list for the provider.

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODELS=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=

GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_MODELS=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODELS=

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODELS=

KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODELS=

MINIMAX_API_KEY=
# MiniMax Anthropic-compatible endpoint for the built-in Anthropic SDK integration
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic/v1
# Example: MiniMax-M2.7,MiniMax-M2.7-highspeed,MiniMax-M2.5,MiniMax-M2.1
MINIMAX_MODELS=

GLM_API_KEY=
GLM_BASE_URL=
GLM_MODELS=

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=
SILICONFLOW_MODELS=

DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODELS=

GROK_API_KEY=
GROK_BASE_URL=
GROK_MODELS=

# --- Ollama (Local Models) ---------------------------------------------------
# No API key needed. Configure BASE_URL here (server-side) so it bypasses SSRF
# protection automatically. Client-supplied localhost URLs are blocked in production.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODELS=llama3.3,llama3.2,qwen2.5,mistral,gemma3

# --- TTS (Text-to-Speech) ----------------------------------------------------

TTS_OPENAI_API_KEY=
TTS_OPENAI_BASE_URL=

TTS_AZURE_API_KEY=
TTS_AZURE_BASE_URL=

TTS_GLM_API_KEY=
TTS_GLM_BASE_URL=

TTS_QWEN_API_KEY=
TTS_QWEN_BASE_URL=

TTS_MINIMAX_API_KEY=
# MiniMax TTS endpoint (speech-2.8 / 2.6 / 02 / 01 series)
TTS_MINIMAX_BASE_URL=https://api.minimaxi.com
TTS_ELEVENLABS_API_KEY=
TTS_ELEVENLABS_BASE_URL=

# --- ASR (Automatic Speech Recognition) --------------------------------------

ASR_OPENAI_API_KEY=
ASR_OPENAI_BASE_URL=

ASR_QWEN_API_KEY=
ASR_QWEN_BASE_URL=

# --- PDF Processing -----------------------------------------------------------

PDF_UNPDF_API_KEY=
PDF_UNPDF_BASE_URL=

# MinerU cloud API (mineru.net) — uses your JWT Token, processes zip in memory via MinIO:
#   PDF_MINERU_BASE_URL=https://mineru.net
#   PDF_MINERU_API_KEY=<JWT Token from https://mineru.net/apiManage>
#   Requires MINIO_PUBLIC_URL to be set so MinerU can fetch the PDF file.
# Optional: override REST API host only (defaults to origin of PDF_MINERU_BASE_URL or https://mineru.net).
# PDF_MINERU_CLOUD_API_BASE=https://mineru.net
# Optional: max wait for task completion when polling (seconds). Default 900 (15 minutes).
# PDF_MINERU_CLOUD_TIMEOUT_MS=900
# MinerU self-hosted (local FastAPI server) — direct multipart upload, synchronous:
#   PDF_MINERU_BASE_URL=http://your-mineru-server:8888
#   PDF_MINERU_API_KEY=   (leave empty unless your deployment requires auth)
PDF_MINERU_API_KEY=
PDF_MINERU_BASE_URL=

# --- Image Generation ---------------------------------------------------------

IMAGE_SEEDREAM_API_KEY=
IMAGE_SEEDREAM_BASE_URL=

IMAGE_QWEN_IMAGE_API_KEY=
IMAGE_QWEN_IMAGE_BASE_URL=

IMAGE_NANO_BANANA_API_KEY=
IMAGE_NANO_BANANA_BASE_URL=

IMAGE_MINIMAX_API_KEY=
# Example models: image-01, image-01-live
IMAGE_MINIMAX_BASE_URL=https://api.minimaxi.com

IMAGE_GROK_API_KEY=
IMAGE_GROK_BASE_URL=

# --- Video Generation ---------------------------------------------------------

VIDEO_SEEDANCE_API_KEY=
VIDEO_SEEDANCE_BASE_URL=

VIDEO_KLING_API_KEY=
VIDEO_KLING_BASE_URL=

VIDEO_VEO_API_KEY=
VIDEO_VEO_BASE_URL=

VIDEO_SORA_API_KEY=
VIDEO_SORA_BASE_URL=

VIDEO_MINIMAX_API_KEY=
# Example models: MiniMax-Hailuo-2.3, MiniMax-Hailuo-2.3-Fast, MiniMax-Hailuo-02
VIDEO_MINIMAX_BASE_URL=https://api.minimaxi.com

VIDEO_GROK_API_KEY=
VIDEO_GROK_BASE_URL=

# --- Web Search ---------------------------------------------------------------
# Note: Grok (xAI) web search is available via chat completions + search tools,
# not as a standalone search API. Use Grok LLM provider with search_parameters
# in chat requests. See: https://docs.x.ai/docs/guides/tools/search-tools

TAVILY_API_KEY=

# --- Proxy (optional) --------------------------------------------------------

# HTTP_PROXY=
# HTTPS_PROXY=

# --- Misc ---------------------------------------------------------------------

# Optional server-side default model for API routes like /api/generate-classroom
# Example: anthropic:claude-3-5-haiku-20241022 or google:gemini-3-flash-preview
# MiniMax example: minimax:MiniMax-M2.7-highspeed
DEFAULT_MODEL=

# Optional server-side default providers (applied on first client setup only).
# When set, the client selects this provider instead of the first available one.
# If the specified provider is not server-configured, it falls back to the first available.
# Example values: qwen-tts, openai-whisper, seedream, seedance
# DEFAULT_TTS_PROVIDER=
# DEFAULT_ASR_PROVIDER=
# DEFAULT_IMAGE_PROVIDER=
# DEFAULT_VIDEO_PROVIDER=

# Optional: control whether image/video generation is enabled by default.
# When not set, generation is automatically enabled if the server has at least one provider.
# Set to "false" to keep generation off even when providers are available.
# DEFAULT_IMAGE_GENERATION_ENABLED=true
# DEFAULT_VIDEO_GENERATION_ENABLED=true

# LOG_LEVEL=info
# LOG_FORMAT=pretty
# LLM_THINKING_DISABLED=false

# --- Local/Self-hosted Deployment ---------------------------------------------
# Set to "true" to allow private/local network URLs (e.g. localhost, 192.168.x.x).
# Required for self-hosted models like Ollama. Do NOT enable on public deployments.
# ALLOW_LOCAL_NETWORKS=true

# --- Casdoor ------------------------------------------------------------------
# Public browser URL of this app (scheme + host + port, no trailing slash).
# For multi-domain deployments (e.g. multiple custom domains on Vercel), do NOT set this —
# the origin is auto-detected from x-forwarded-host headers per request. Only set this for
# bare Node.js deployments where the Host header is unreliable (e.g. 0.0.0.0).
# APP_PUBLIC_URL=https://openmaic.example.com
CASDOOR_ENDPOINT=https://localhost:8000
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
CASDOOR_CERTIFICATE=
CASDOOR_ORG_NAME=built-in
CASDOOR_APP_NAME=app-built-in

# --- Role-based button permissions (RBAC) -------------------------------------
# Two layered modes are available (see docs/permissions.md):
#
# 1. Casdoor casbin enforce mode (recommended for new deploys)
#    Set CASDOOR_RBAC_ENABLED=true and configure roles + policies in the
#    Casdoor dashboard. The app calls /api/batch-enforce against the
#    permission identified by `<CASDOOR_ORG_NAME>/<CASDOOR_PERMISSION_NAME>`
#    on login (snapshotted for MENU_PERMISSIONS_TTL_MS).
# CASDOOR_RBAC_ENABLED=false
# CASDOOR_PERMISSION_NAME=openmaic-menus
# CASDOOR_PERMISSION_DOMAIN=built-in
# MENU_PERMISSIONS_TTL_MS=1800000
#
# 2. Legacy env mapping (fallback when CASDOOR_RBAC_ENABLED is unset/false)
#    Map Casdoor roles/groups/tag to actions the UI may gate on. Owners of
#    a classroom/resource implicitly get regenerate/edit-source/reorder/
#    delete-scene/add-scene/share; this env only matters for non-owner
#    viewers and for `delete-classroom`.
#    Format: role:action,action|role:*|role:
#      `*` grants every action; empty list = role recognized but no grants.
#    Known actions: regenerate, edit-source, reorder, delete-scene,
#                   add-scene, share, delete-classroom
# OPENMAIC_ROLE_PERMISSIONS=admin:*|teacher:regenerate,edit-source,reorder,delete-scene,add-scene,share|student:

# --- PostgreSQL ---------------------------------------------------------------
DATABASE_URL=postgresql://openmaic:openmaic@localhost:5432/openmaic

# --- MinIO (Object Storage) ---------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=openmaic
MINIO_SECRET_KEY=openmaic123
MINIO_BUCKET=openmaic
MINIO_USE_SSL=false
# Optional: public URL for MinIO (when behind a CDN/proxy). If unset, media
# is served through the Next.js API proxy.
# MINIO_PUBLIC_URL=https://cdn.example.com

# --- Credits ------------------------------------------------------------------
# Initial credits granted to new users
INITIAL_CREDITS=100
# Optional: recharge / billing URL for the UI (e.g. external checkout). If unset, "Go to recharge"
# links to /credits/recharge. Use https://... to open in a new tab.
# NEXT_PUBLIC_CREDITS_RECHARGE_URL=https://billing.example.com/top-up

# --- gRPC ---------------------------------------------------------------------
GRPC_SERVER_ADDRESS=localhost:50051
